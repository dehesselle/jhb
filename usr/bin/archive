### description ################################################################

# This is a helper to create release archives and mount them.

### shellcheck #################################################################

# Nothing here.

### dependencies ###############################################################

source "$(dirname "${BASH_SOURCE[0]}")"/../../etc/jhb.conf.sh

### variables ##################################################################

ARCHIVE_DMG=${ARCHIVE_DMG:-$DIR_ARTIFACT/$(\
  basename -s .tar.xz "$RELEASE_ARCHIVE").dmg}

### functions ##################################################################

function create_tar
{
  local file
  file=$DIR_ARTIFACT/$RELEASE_ARCHIVE

  echo_i "creating $file"

  tar -C "$DIR_WORK" \
      --exclude="$(basename "$DIR_TMP")"/?* \
      -cp "$(basename "$DIR_VERSION")" |
    XZ_OPT=-T0 "$DIR_BIN"/xz >"$file"

  shasum -a 256 "$file" >"$file".sha256
  echo_i "sha256 = $(awk '{ print $1 }' "$file".sha256)"

  echo "$file"
}

function create_dmg
{
  ( # create dmg
    local vol_name
    vol_name=$(basename "$DIR_VERSION")

    cd "$DIR_WORK" || exit 1
    hdiutil create -ov \
      -fs HFS+ \
      -format ULMO \
      -size 16g \
      -srcfolder "$vol_name" \
      -volname "$vol_name" \
      "$ARCHIVE_DMG" \
      >/dev/null
  )

  ( # create and print checksum
    cd "$(dirname "$ARCHIVE_DMG")" || exit 1
    shasum -a 256 "$(basename "$ARCHIVE_DMG")" >"$ARCHIVE_DMG".sha256
    echo_i "sha256 = $(awk '{ print $1 }' "$ARCHIVE_DMG".sha256)"
  )

  echo "$ARCHIVE_DMG"
}

function mount_dmg
{
  local shadow_file=$ARCHIVE_DMG.shadow

  if [ ! -d "$DIR_VERSION" ]; then
    mkdir -p "$DIR_VERSION"
  fi

  if [ -f "$shadow_file".bz2 ]; then
    echo_i "decompressiong $shadow_file.bz2 ..."
    bzip2 -d "$shadow_file".bz2
  fi

  echo_i "mounting $(basename "$ARCHIVE_DMG")"
  hdiutil mount "$ARCHIVE_DMG" \
    -mountPoint "$DIR_VERSION" \
    -shadow "$shadow_file"
}

function unmount_dmg
{
  local keep_shadow_file=$1

  local shadow_file=$ARCHIVE_DMG.shadow

  if [ -f "$ARCHIVE_DMG" ]; then
    local partition_uuid
    partition_uuid=$(hdiutil imageinfo "$ARCHIVE_DMG" |
        grep -A1 "partition-name: disk image" |
        grep UUID |
        awk '{ print $2 }')

    if [ -n "$partition_uuid" ] && hdiutil info | grep "$partition_uuid"; then
      echo_i "unmounting $DIR_VERSION"
      # We loop over the 'eject' since it occasionally timeouts.
      while ! hdiutil detach "$DIR_VERSION" >/dev/null; do
        echo_w "retrying to detach $DIR_VERSION in 10 seconds"
        sleep 10
      done

      case "$keep_shadow_file" in
        keep)
          echo_i "keeping $shadow_file"
          ;;
        archive)
          echo_i "archiving $shadow_file ..."
          bzip2 "$shadow_file"
          ;;
        *)
          echo_i "removing $shadow_file"
          rm "$shadow_file"
          ;;
      esac
    else
      echo_i "nothing to unmount"
    fi
  else
    echo_e "cannot unmount without dmg file"
  fi
}

function remove_nonessential_files
{
  local additional_dirs=$1  # optional

  for dir in $DIR_BUILD $PIP_CACHE_DIR $DIR_PKG $PYTHONPYCACHEPREFIX \
             $DIR_SRC $DIR_TMP $additional_dirs; do
    dir=$(eval echo "$dir") # allow variable resolution for additional_dirs

    if [[ $dir != $DIR_VERSION/* ]]; then
      # this is a precaution: do not touch things outside our tree
      echo_i "skipping $dir: not below DIR_VERSION"
      continue
    fi

    if [ -f "$dir/.skip_remove_nonessential_files" ]; then
      echo_i "skipping $dir: .skip_remove_nonessential_files was found"
      continue
    fi

    while IFS= read -r -d "" object; do
      if [ "$(basename "$object")" = ".keep" ]; then
        continue  # do not remove the "keep"-list itself
      fi
      if ! grep "$(basename "$object")" "$(dirname "$object")/.keep" \
          -q 2>/dev/null; then
        rm -rf "${object:?}"
      else
        echo_i "keeping $object"
      fi
    done < <(find "$dir" -maxdepth 1 -mindepth 1 -print0)
  done
}

function main
{
  local command=$1
  local option=$2

  case "$command" in
    create_dmg)
      create_dmg
      ;;
    create_tar)
      create_tar
      ;;
    mount_dmg)
      mount_dmg
      ;;
    unmount_dmg)
      unmount_dmg "$option" # option: keep shadow file or not
      ;;
    remove_nonessentials)
      remove_nonessential_files "$option" # option: additional dirs to clean up
      ;;
    *)
      echo_e "usage: $0 {create_dmg|create_tar|mount_dmg|unmount_dmg|\
remove_nonessentials}"
      ;;
  esac
}

### main #######################################################################

error_trace_enable

main "$@"
